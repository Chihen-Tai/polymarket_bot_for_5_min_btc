# 模式：true 代表只做 dry-run，不會真的送出實盤訂單
DRY_RUN=false

# 本 repo 會先讀這份追蹤中的 .env，再讀本機的 `.env.local` / `.env.secrets` 覆蓋敏感值。
# 所以真正的 API / 私鑰建議放到本機覆蓋檔，不要直接填在這份檔案裡。

# 最低淨值：低於這個資金水位就停止開新單
MIN_EQUITY=0
# 單筆下單金額：先用 1 美元試單，賣出分批不受 1 美元限制
MAX_ORDER_USD=1.0
# Live 進場預設走 market/taker，先買固定 1 美元部位
LIVE_ENTRY_USE_MARKET_ORDERS=true
# Live 最小下單張數：只有在 LIVE_ENTRY_USE_MARKET_ORDERS=false 的 maker 模式才會用到
MIN_LIVE_ORDER_SHARES=5.0
# Live 最小名目金額：如果取整後低於這個值，允許小幅自動補單
MIN_LIVE_ORDER_USD=1.0
# Live 單筆硬上限：基準先下 1 美元，只在必要時補到可成交，但最多補到這個值
LIVE_ORDER_HARD_CAP_USD=3.0
# 總曝險上限：優化階段暫時拉高，避免 exposure limit 干擾
MAX_EXPOSURE_USD=9999.0
# 每 5 分鐘最多嘗試下單次數
MAX_ORDERS_PER_5MIN=3
# 連續虧損上限：優化階段暫時拉高，避免過早熔斷
MAX_CONSEC_LOSS=3
# 乾淨重啟且超過一個市場週期都沒新交易時，自動清掉陳舊的連敗熔斷狀態
CLEAN_START_LOSS_STREAK_RESET_SEC=300
# 單日最大可容忍虧損：優化階段暫時拉高
DAILY_MAX_LOSS=3
# 若要同一天手動重置 daily max loss，啟動前改成 1；重置完請改回 0
MANUAL_RESET_DAILY_MAX_LOSS_ON_START=0
# 保守模式：目標先是少虧或不虧，而不是追求交易頻率
CONSERVATIVE_MODE_ENABLED=true
# 在原本 required_edge 上再多加 1.5%，把邊際單再往外擋一層
CONSERVATIVE_EXTRA_EDGE=0.015
# 保守模式下最多只同時留 1 筆持倉；一般設定仍可保留較高上限供之後調整
CONSERVATIVE_MAX_OPEN_POSITIONS=1
# 保守模式下每 5 分鐘最多只允許 2 次新倉決策
CONSERVATIVE_MAX_ORDERS_PER_5MIN=2
# 只要有一次 live sync miss，就先停止開新單，等同步重新乾淨
CONSERVATIVE_SYNC_MISS_LIMIT=1
CONSERVATIVE_BLOCK_PENDING_ORDERS=true
CONSERVATIVE_BLOCK_PENDING_CONFIRMATION=true
CONSERVATIVE_BLOCK_LIVE_SYNC_PROTECT=true

# 輪詢間隔：一般市場每 2 秒檢查一次
POLL_SECONDS=2
# Live 帳戶快取：短時間重用最近一次 account snapshot，減少 get_account API 壓力
LIVE_ACCOUNT_CACHE_TTL_SEC=6
# 掛單待成交時改成更快輪詢，盡量接近每秒關心一次訂單
PENDING_ORDER_POLL_SECONDS=1
# 已持倉時也改成更快輪詢，讓止盈 / 止損不要慢半拍
OPEN_POSITION_POLL_SECONDS=1
# 接近停損時再臨時切到更快輪詢，盡量把 decision=stop-loss 到真正 EXIT 的落差壓短
NEAR_STOP_POLL_SECONDS=0.5
NEAR_STOP_POLL_HOLD_SEC=15
# 每隔幾秒記一次持倉診斷 log，方便追止盈 / 止損慢半拍問題
POSITION_WATCH_DEBUG_ENABLED=true
POSITION_WATCH_LOG_INTERVAL_SEC=5

# Discord 通知 Webhook：要公開上傳，所以目前保持空白
DISCORD_WEBHOOK_URL=

# Polymarket CLOB 與資料 API 位址
CLOB_HOST=https://clob.polymarket.com
DATA_API_HOST=https://data-api.polymarket.com
CHAIN_ID=137

# 簽章型態：
# 0 = 一般 EOA 錢包
# 1 = email / Magic wallet
# 2 = proxy / smart wallet
SIGNATURE_TYPE=2

# 敏感欄位：因為這份 .env 會上傳 GitHub，所以保持空白
PRIVATE_KEY=
FUNDER_ADDRESS=

# Live CLOB API 憑證：
# 若留空，bot 會嘗試自行 derive；若你的帳戶是 proxy / smart wallet，
# 通常直接填正確的 CLOB_API_* 會更穩。
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# 額外運維欄位：目前 bot 本身不會讀這些值，
# 但保留在同一份 .env 方便你在 Linux / production 環境集中管理。
RELAYER_URL=
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
PROXY_WALLET=
BUILDER_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# 自動挑選最新 BTC 5 分鐘市場
AUTO_MARKET_SELECTION=true
MARKET_SLUG_PREFIX=btc-updown-5m-
# 進場過濾底線保護：常規統計策略的最低進場價 ($0.35) 防止購買垃圾賠率。
MIN_ENTRY_PRICE=0.35
# 狙擊手通行證：ws_flash_snipe 可以買這種便宜樂透單 ($0.05 起) 以博取 500%~1900% 暴漲。
SNIPE_MIN_ENTRY_PRICE=0.05

# 入場 edge 門檻：提高到 8%，過濾邊緣訊號（edge=0.055 這類的全部丟掉）
EDGE_THRESHOLD=0.08
# 手續費底線緩衝倍數：required_edge >= fee_rate * 2 * buffer
# 0.0156 * 2 * 1.2 ≈ 0.0374，確保進場時費後期望值為正
ENTRY_FEE_FLOOR_BUFFER=1.2
# 交易成本 / 誤差緩衝
FEE_BUFFER=0.01
# 報表中把絕對報酬落在 3% 內的交易視為 scratch / flat trade
REPORT_SCRATCH_PNL_PCT=0.03
# 均值回歸用的觀察窗長度
ZSCORE_WINDOW=10
# ❌ 均值回歸策略：5分鐘二元期權不適用均值回歸（越接近結算越收斂到0或1），設超高門檻永不觸發
ZSCORE_THRESHOLD=99.0
# 進場最有把握的可接受剩餘秒數：收緊到剩不到 60 秒不再開新單，盡量避開晚盤追價
ENTRY_WINDOW_MIN_SEC=60
# 進場最早時間：再提早 10 秒開始觀察，增加早段有力 order-flow 的成交機會
ENTRY_WINDOW_MAX_SEC=285
# 最大同時持倉數量：允許 2 個倉位同時運行，增加交易頻率
MAX_OPEN_POSITIONS=2
# 獲利單最後大逃殺時間：往後放到倒數 35 秒，讓贏家多跑一點，但仍在空城前保留出場緩衝
EXIT_DEADLINE_PROFIT_SEC=35
# 空城鎖定機制（Ghost Town Lock）：微幅割頭皮模式下「必須歸零」，因為我們就是要在最後幾秒也能自由停損停利！絕不留倉被結算！
EXIT_GHOST_TOWN_SEC=0
# 最高可接受買價：再收緊到 0.70，減少高價票的小賺大賠結構
MAX_ENTRY_PRICE=0.70
# 實際成交均價若比預期進場價高太多，視為異常滑價並立刻強制平掉
ENTRY_SLIPPAGE_GUARD_ENABLED=true
ENTRY_MAX_ACTUAL_SLIPPAGE_PCT=0.18
# 太接近 50/50 的價位容易變成 scratch trade，因此要求更高 edge
ENTRY_NEUTRAL_BAND_HALF_WIDTH=0.03
ENTRY_NEUTRAL_EDGE_PENALTY=0.02
# 極度接近正反五五波時再加一層更嚴格的過濾
ENTRY_MICRO_BAND_HALF_WIDTH=0.01
ENTRY_MICRO_EDGE_PENALTY=0.02
# 如果 UP/DOWN 兩邊最佳候選太接近，直接不做，避免硬猜方向
ENTRY_SIDE_CONFLICT_ENABLED=true
ENTRY_SIDE_CONFLICT_MIN_EDGE_GAP=0.025
ENTRY_SIDE_CONFLICT_MIN_PROB_GAP=0.03

# 若關掉 AUTO_MARKET_SELECTION，可手動指定 token id；公開版保持空白
TOKEN_ID_UP=
TOKEN_ID_DOWN=

# 硬停損速度護盾：目前關閉，避免延後止損
ENABLE_HARD_STOP_SHIELD=false
HARD_STOP_SHIELD_VELOCITY=0.0004
# OFI 強訊號閾值：提高到 0.76，只進高信心訊號，過濾掉「剛剛超過閾值就進場」的邊緣單
OFI_BYPASS_THRESHOLD=0.76
# Scoreboard 歷史勝率硬封鎖：暫時降到 10%，因為我們換成了全新的微幅割頭皮模式，先前的歷史敗績不再適用，讓策略重新證明自己
SCOREBOARD_MIN_WIN_RATE=0.10
# Scoreboard 指數衰減率：時間越久遠的交易，在勝率計算中的權重越低 (1.0 = 不衰減，0.95 = 5% 衰減)
SCOREBOARD_DECAY_FACTOR=0.95
# 反轉型 dump trigger 預設關閉，避免繞過正式方向選擇
ENABLE_DUMP_TRIGGER=false
# 入口需要同時通過 lagged 與 current Binance 短線方向確認
ENTRY_DUAL_VELOCITY_CONFIRM=true
# WebSocket 閃電狙擊閾值：越低越容易抓到短線脈衝 (降低以增加頻率)
WS_FLASH_SNIPE_THRESHOLD=0.0014
# 幣安爆倉狙擊：當發生超過這個金額 (美元) 的強制平倉時，進行均值回歸撿屍
LIQUIDATION_FADE_MIN_USD=500000.0
# 幣安爆倉狙擊的有效時間 (秒)：爆倉發生後多少秒內買進算有效
LIQUIDATION_FADE_WINDOW_SEC=20.0
# 動能最小變化量：避免太弱的價格變動被當成趨勢 (放寬以捕捉小波動)
MOMENTUM_MIN_MOVE=0.0020

# ❌ 第12號策略：逆勢爆擊已停用 — 35%以下的逆勢便宜票在5分鐘市場沒有足夠Edge，且允許-35%死抱與微幅割頭皮矛盾
EARLY_UNDERDOG_MAX_PRICE=0.01
EARLY_UNDERDOG_MIN_TIME=99999.0
# 鎖定離場機制：縮短死區時間，直到剩下 這幾秒 之前絕不停損或停利（提前到 180秒 解鎖 = 剩下 3 分鐘時就放開風控）
EARLY_UNDERDOG_EXIT_LOCK_TIME=180.0
# 深套躺平機制：如果這張單虧損超過 35% (例如 -40%)，直接放棄止損抱到結算；只有在虧損 30% 以內才做常規止損
EARLY_UNDERDOG_LET_RIDE_LOSS_PCT=0.35
# 樂透爆發模式偵測門檻：
# 只有在「持倉後 N 秒內就出現 M% 以上漲幅」才視為「爆發型樂透單」，啟動鎖定 + 等 150%。
# 未達此條件的 early_underdog 單，完全視為一般單（正常 30% 停利、正常停損）。
LOTTERY_BURST_WINDOW_SEC=60.0     # 偵測窗口：60 秒內
LOTTERY_BURST_MIN_PCT=0.50        # 最低爆發幅度：50% 以上才算（一分鐘 50%+ = 誇張斜率）
# 樂透高原停利：在 +75% ~ +150% 區間，若停止創高 N 秒且 Binance 不再強勢推升，視為動能耗盡停利
# 若 Binance 速度仍強（>= velocity_threshold），讓它繼續衝 150%
LOTTERY_PLATEAU_MIN_PCT=0.75           # 高原停利啟動下限（75%）
LOTTERY_PLATEAU_STALL_SEC=15.0         # 距上次創高超過幾秒才視為「穩定/高原」
LOTTERY_PLATEAU_VELOCITY_THRESHOLD=0.0003  # Binance 速度低於此值才停利（高於此值 = 還在漲，繼續持有）
# 專屬停利機制：強制蓋掉原本 25% 就停利的設定，樂透單沒有漲到 1.5 倍 (150%) 絕不賣飛！
EARLY_UNDERDOG_TAKE_PROFIT_PCT=1.50

# 第一段止盈：獲利達 5% 時就先啟動「微幅割頭皮」，瞬間鎖倉避免勝率被震盪吃掉
TAKE_PROFIT_SOFT_PCT=0.05
# Mark-price Fallback 停利緩衝：當 bid 可成交報酬因流動性打折達不到停利門檻，
# 但帳面 mark 報酬已超過 TAKE_PROFIT_SOFT_PCT + 此緩衝值，就強制用 mark 報酬觸發停利。
# 例如 0.05 = mark 須達到 5%+5%=10% 才觸發 fallback（確保 bid 打折也能被抓到）
TAKE_PROFIT_BID_DISCOUNT_BUFFER=0.05
# 軟保本賣出的比例 -> 賣出 100%，做短線閃擊就是要落袋為安
TAKE_PROFIT_PARTIAL_FRACTION=1.0
# 如果直接飛天，獲利達到 10% 就先抽回本金，避免大贏家在安全前整段回吐
TAKE_PROFIT_HARD_PCT=0.10
# partial 之後若 runner 一度衝到 24% 以上，但開始明顯回吐，就提早抽回本金。
TAKE_PROFIT_PRINCIPAL_AFTER_PARTIAL_ENABLED=true
TAKE_PROFIT_PRINCIPAL_AFTER_PARTIAL_MIN_MFE_PCT=0.24
TAKE_PROFIT_PRINCIPAL_AFTER_PARTIAL_DRAWDOWN_PCT=0.08
TAKE_PROFIT_PRINCIPAL_AFTER_PARTIAL_MIN_CURRENT_PCT=0.14
TAKE_PROFIT_RUNNER_FRACTION=0.10
# 本金抽回後，runner 若在 45 秒內從局部高點回落超過 35%，才提早保護性賣出
MOONBAG_DRAWDOWN_PCT=0.35
MOONBAG_DRAWDOWN_WINDOW_SEC=45
MOONBAG_MIN_PEAK_VALUE_USD=0.10
# 最長持倉秒數：縮短到 90 秒，讓虧損單更快釋放，誓口給下一筆進場機會
MAX_HOLD_SECONDS=90
# 晚進場額外懲罰：避免太晚追價
LATE_ENTRY_EDGE_PENALTY=0.005
# 高價格額外懲罰：避免在太貴的位置追單
RICH_PRICE_EDGE_PENALTY=0.005
# Kelly sizing：關閉，固定用 MAX_ORDER_USD 下單
USE_KELLY_SIZING=false
# Kelly 分母：保留設定供之後打開 Kelly 時使用
BINARY_KELLY_DIVISOR=3.0
# Scoreboard 只做輕微加權，不主導方向
SCOREBOARD_AUX_WEIGHT=0.05
# ===== Moonbag 飛天單設定 =====
# 強制全出，因為我們現在改走微幅割頭皮 (Micro-scalping) 模式，落袋為安
FORCE_FULL_EXIT_ON_TAKE_PROFIT=true
LIVE_TAKE_PROFIT_FORCE_TAKER=true
# 大盈利後如果從局部高點明顯回撤，且 Binance 速度轉壞，就提早保護性出場
PROFIT_REVERSAL_ENABLED=true
PROFIT_REVERSAL_MIN_MFE_PCT=0.25
PROFIT_REVERSAL_MIN_CURRENT_PROFIT_PCT=0.08
PROFIT_REVERSAL_DRAWDOWN_PCT=0.12
PROFIT_REVERSAL_ADVERSE_VELOCITY=0.0003
# 只有 Binance 真的很強順向推進時，才延後止盈
TP_HOLD_VELOCITY=0.00045
# Binance 明顯先反向時，對還沒進入安全盈利的倉位做提前退出
BINANCE_ADVERSE_EXIT_ENABLED=true
BINANCE_ADVERSE_EXIT_CONFIRM_SEC=3
BINANCE_ADVERSE_EXIT_VELOCITY=0.00035
BINANCE_ADVERSE_EXIT_MAX_PROFIT_PCT=0.08
BINANCE_ADVERSE_EXIT_MIN_HOLD_SEC=4
BINANCE_ADVERSE_EXIT_REQUIRE_CURRENT_CONFIRM=true
# 小賺但不再創高、且 Binance 先轉弱時，更積極把利潤拿走
BINANCE_PROFIT_PROTECT_ENABLED=true
BINANCE_PROFIT_PROTECT_MIN_PROFIT_PCT=0.08
BINANCE_PROFIT_PROTECT_MAX_PROFIT_PCT=0.18
BINANCE_PROFIT_PROTECT_STALL_SEC=8.0
BINANCE_PROFIT_PROTECT_CONFIRM_SEC=1
BINANCE_PROFIT_PROTECT_VELOCITY=0.00012
BINANCE_PROFIT_PROTECT_MIN_HOLD_SEC=8
BINANCE_PROFIT_PROTECT_REQUIRE_CURRENT_CONFIRM=false
# 第一段止損只給很短確認時間，避免虧損單拖大
SOFT_STOP_CONFIRM_SEC=2.5
SOFT_STOP_CONFIRM_BUFFER_PCT=0.015
SOFT_STOP_ADVERSE_VELOCITY=0.00018

# 關閉智慧型提前全平，改用固定的分段止損規則
SMART_STOP_LOSS_ENABLED=false
# 帳面虧損達多少時，啟動第一階段「軟停損」(砍掉部分倉位) -> 提前到 22%，讓實際單筆虧損更容易落在 -0.20~-0.25
STOP_LOSS_PARTIAL_PCT=0.22
# 「軟停損」砍掉的比例
STOP_LOSS_PARTIAL_FRACTION=0.50
# 在 live 模式下，軟停損的比例可以調高，確保砍得更乾淨
LIVE_STOP_LOSS_PARTIAL_FRACTION=0.80
# 帳面虧損達多少時，啟動「硬停損」(全部市價砍倉) -> 收緊到 35%，配合快速 taker retry，把實際虧損收斂到 -0.20~-0.25
STOP_LOSS_PCT=0.35
# 在接近停損前，何時發出警告 log：提前到 18%，方便更早觀察風險
STOP_LOSS_WARN_PCT=0.18
# 到期前最後退出秒數：剩不到 35 秒時，還沒回本的單不再硬抱
EXIT_DEADLINE_SEC=35
# stop-loss 類退出改成更密的 taker retry，避免每輪等太久
LOSS_EXIT_RETRY_DELAY_SEC=0.25
LOSS_EXIT_MAX_ATTEMPTS=4
# 近結算緊急退出：deadline 類平倉改成 1 秒節奏重試，避免最後幾秒才開始賣卻來不及
EMERGENCY_EXIT_RETRY_DELAY_SEC=1
EMERGENCY_EXIT_MAX_ATTEMPTS=8
# stop-loss scale-out 如果只成交到預期 clip 的 60% 以下，就不要把它當成正常分段保護
STOP_LOSS_SCALEOUT_EMERGENCY_FILL_RATIO=0.60
# stop-loss scale-out 後若還殘留超過 45% 的本金風險，立刻升級成 residual-force-close
STOP_LOSS_SCALEOUT_EMERGENCY_REMAINING_COST_PCT=0.45
# 到期前平手退出門檻：<= 0 代表連平手都先出，避免最後被結算歸零
EXIT_DEADLINE_FLAT_PNL_PCT=0.00
# 第一段止損先只砍大部分，保留一小段倉位觀察是否快速修復
FORCE_FULL_EXIT_ON_STOP_LOSS_SCALEOUT=false
# 第一段止損後，剩下的小倉位至少給 15 秒恢復時間
POST_SCALEOUT_LOSS_EXIT_DELAY_SEC=15
# 若恢復窗過後仍然深虧到 16% 以上，才把殘部位整筆退掉
POST_SCALEOUT_LOSS_EXIT_PCT=0.16
# Live 虧損退出：除了 stop-loss-scale-out 之外，其餘虧損型退出直接整筆出
LIVE_FORCE_FULL_LOSS_EXIT=true
# Live 虧損退出走 taker，確保停損單在市場有流動性時能快速成交
LIVE_LOSS_EXIT_FORCE_TAKER=true
LIVE_TAKE_PROFIT_FORCE_TAKER=true
LEAVE_MOONBAG_PCT=0.05
# 先不要留虧損尾倉，避免 stop-loss 後又把虧損拖進 expiry。
LEAVE_LOSS_TAIL_PCT=0.00

# 如果一筆單曾經有明顯浮盈（>= 8%），但後來整段回吐到接近平盤，就直接全退。
# 這條專門處理 5 分鐘盤裡「本來有贏、最後又拖成大虧」的單。
BREAKEVEN_GIVEBACK_ENABLED=true
BREAKEVEN_GIVEBACK_MIN_MFE_PCT=0.08
BREAKEVEN_GIVEBACK_FLOOR_PCT=0.03
BREAKEVEN_GIVEBACK_MIN_HOLD_SEC=12
BREAKEVEN_GIVEBACK_MIN_SECS_LEFT=45

# 如果一筆單進場後 25 秒仍幾乎完全沒 follow-through，且已經落到 -2%，就直接砍。
# 這條是為了處理「完全沒起飛，最後卻拖成 -0.3 ~ -0.5」的輸家。
FAILED_FOLLOW_THROUGH_WINDOW_SEC=25
FAILED_FOLLOW_THROUGH_LOSS_PCT=0.02
# 只有連像樣的順風都沒出現時，才算 failed follow-through。
FAILED_FOLLOW_THROUGH_MAX_MFE_PCT=0.015
# 至少還要剩 120 秒才做這種早退，保留重新抓同市場乾淨訊號的空間。
FAILED_FOLLOW_THROUGH_MIN_SECS_LEFT=120
# 若進場後 35 秒幾乎沒 follow-through，且還有時間重抓，提早釋放 dead money
STALLED_EXIT_WINDOW_SEC=35
# 只有已經出現至少 1% 的逆向漂移，才把「卡住單」視為需要提早撤退；避免完全同價進出
STALLED_EXIT_MIN_LOSS_PCT=0.01
# 價格仍在成本附近才視為 stalled，避免太早砍掉真的開始跑的單
STALLED_EXIT_MAX_ABS_PNL_PCT=0.02
# 若期間連 2% 的順風都沒出現，代表這筆單很可能只是卡住
STALLED_EXIT_MAX_MFE_PCT=0.02
# 至少還要剩 45 秒才做 stalled exit，保留同市場重進空間
STALLED_EXIT_MIN_SECS_LEFT=45
# 同市場重新進場的最小剩餘秒數，配合 stalled exit 留一點重抓時間
SAME_MARKET_REENTRY_MIN_SECS_LEFT=45
# Binance 訊號延後 0.5 秒使用，與 Polymarket order book 更貼近
BINANCE_SIGNAL_LAG_SEC=0.5
# 進場時可接受的最大 bid/ask spread；超過代表流動性條件太差
ENTRY_MAX_SPREAD=0.03
# 最佳 ask 至少要能吃下預估部位的幾倍；小幅放寬，增加可成交機會但仍保留第一檔厚度要求
ENTRY_MIN_BEST_ASK_MULTIPLE=1.5
# ask 總深度至少要有預估部位的幾倍；從 6x 放寬到 4x，降低過度保守造成的錯失
ENTRY_MIN_TOTAL_ASK_MULTIPLE=4.0

# WS 斷流容忍秒數：超過就暫停新單
WS_STALE_MAX_AGE_SEC=7
# WS 連續過期幾輪後啟動 fail-safe
WS_STALE_FAIL_SAFE_STREAK=3
# API 反應太慢的判定毫秒數
API_SLOW_THRESHOLD_MS=2200
# API 連續失敗幾輪後啟動 fail-safe
API_FAIL_SAFE_STREAK=4
# 網路恢復幾輪後解除 fail-safe
NETWORK_RECOVERY_STREAK=1
# 最低進場速度：太慢的價格脈衝不追
ENTRY_VELOCITY_MIN=0.0002
# 同方向進場冷卻：已有同方向倉位時，N 秒內不再重複進同方向。
# 防止訊號重複觸發造成雙倍虧，設 0 可停用。
SAME_DIRECTION_ENTRY_COOLDOWN_SEC=60.0
# 真實下單失敗時的短重試次數
ENTRY_RETRY_ATTEMPTS=3
# 每次重試之間的等待秒數
ENTRY_RETRY_BACKOFF_SEC=2.0
# maker 掛單超時後，直接用 taker 補單，不再只是 cancel 掉
MAKER_TIMEOUT_FALLBACK_TAKER=true
# 報表用的保守 taker fee 假設，用來估算 fee-adjusted pnl
REPORT_ASSUMED_TAKER_FEE_RATE=0.0156
ENTRY_MAX_SPREAD=0.10
