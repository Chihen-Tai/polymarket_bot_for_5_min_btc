# Live template for small-size production testing.
# Fill in your own secrets locally and do not commit them.

# Mode
DRY_RUN=false

# Risk
MIN_EQUITY=0.0
MAX_ORDER_USD=1.0
LIVE_ENTRY_USE_MARKET_ORDERS=true
# Only used when LIVE_ENTRY_USE_MARKET_ORDERS=false (maker entry mode)
MIN_LIVE_ORDER_SHARES=5.0
MIN_LIVE_ORDER_USD=1.0
LIVE_ORDER_HARD_CAP_USD=3.0
MAX_EXPOSURE_USD=3.0
MAX_ORDERS_PER_5MIN=1
MAX_CONSEC_LOSS=99
DAILY_MAX_LOSS=999999999

# Runtime
POLL_SECONDS=3

# Notifications (optional)
DISCORD_WEBHOOK_URL=

# Polymarket CLOB
CLOB_HOST=https://clob.polymarket.com
DATA_API_HOST=https://data-api.polymarket.com
CHAIN_ID=137

# Signature types:
# 0 = direct EOA wallet
# 1 = email / Magic wallet
# 2 = proxy wallet / smart wallet setup
SIGNATURE_TYPE=2

# Signing key used by py-clob-client
PRIVATE_KEY=

# Address that actually holds the funds on Polymarket
FUNDER_ADDRESS=

# Optional fixed API credentials. If blank, the bot will derive credentials.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Operator / infra reference fields.
# The current bot does not read these directly, but keeping them in the same
# .env helps when your deployment workflow needs them.
RELAYER_URL=
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
PROXY_WALLET=
BUILDER_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# Auto market selection (recommended)
AUTO_MARKET_SELECTION=true
MARKET_SLUG_PREFIX=btc-updown-5m-

# Optional static token ids (used when AUTO_MARKET_SELECTION=false)
TOKEN_ID_UP=
TOKEN_ID_DOWN=

# Tuned thresholds (small-size live test)
ENTRY_WINDOW_MIN_SEC=40
ENTRY_WINDOW_MAX_SEC=130
EDGE_THRESHOLD=0.015
ZSCORE_THRESHOLD=1.3
MIN_ENTRY_PRICE=0.30
MAX_ENTRY_PRICE=0.88
MAX_IDLE_MINUTES=5
LIVE_POSITION_GRACE_SEC=90
LIVE_POSITION_MISS_LIMIT=3
DUMP_MOVE_THRESHOLD=0.08
HEDGE_SUM_TARGET=0.95
HEDGE_MAX_WAIT_SEC=90
STOP_LOSS_PCT=0.20
MAX_HOLD_SECONDS=90
TAKE_PROFIT_SOFT_PCT=0.50
TAKE_PROFIT_HARD_PCT=0.50
MOMENTUM_TICKS=3
MOMENTUM_MIN_MOVE=0.01
EXIT_DEADLINE_SEC=20
STOP_LOSS_WARN_PCT=0.12
