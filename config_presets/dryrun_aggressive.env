# 積極版 dry-run 預設：提高交易數，但仍保留風控。
# 這份 preset 與目前主用 .env 對齊，重點是啟用真正的分批止盈 / 分段止損。

DRY_RUN=true
MIN_EQUITY=1.0
MAX_ORDER_USD=1.0
MAX_EXPOSURE_USD=9999.0
MAX_ORDERS_PER_5MIN=6
MAX_CONSEC_LOSS=999
DAILY_MAX_LOSS=9999.0
POLL_SECONDS=4

EDGE_THRESHOLD=0.005
ZSCORE_WINDOW=10
ZSCORE_THRESHOLD=1.8
ENTRY_WINDOW_MIN_SEC=15
ENTRY_WINDOW_MAX_SEC=95
MIN_ENTRY_PRICE=0.18
MAX_ENTRY_PRICE=0.85
OFI_BYPASS_THRESHOLD=0.58
WS_FLASH_SNIPE_THRESHOLD=0.0020
MOMENTUM_MIN_MOVE=0.0035

TAKE_PROFIT_SOFT_PCT=0.30
TAKE_PROFIT_HARD_PCT=0.50
MAX_HOLD_SECONDS=150
ENABLE_HARD_STOP_SHIELD=false
LATE_ENTRY_EDGE_PENALTY=0.005
RICH_PRICE_EDGE_PENALTY=0.005
USE_KELLY_SIZING=false
BINARY_KELLY_DIVISOR=3.0
SCOREBOARD_AUX_WEIGHT=0.05
FORCE_FULL_EXIT_ON_TAKE_PROFIT=false
SMART_STOP_LOSS_ENABLED=false
STOP_LOSS_PARTIAL_PCT=0.15
STOP_LOSS_PARTIAL_FRACTION=0.50
STOP_LOSS_PCT=0.30
STOP_LOSS_WARN_PCT=0.15
EXIT_DEADLINE_SEC=20
EXIT_DEADLINE_FLAT_PNL_PCT=0.00
FORCE_FULL_EXIT_ON_STOP_LOSS_SCALEOUT=false
FAILED_FOLLOW_THROUGH_WINDOW_SEC=9999
FAILED_FOLLOW_THROUGH_LOSS_PCT=0.025
FAILED_FOLLOW_THROUGH_MAX_MFE_PCT=0.015
FAILED_FOLLOW_THROUGH_MIN_SECS_LEFT=70

WS_STALE_MAX_AGE_SEC=7
WS_STALE_FAIL_SAFE_STREAK=3
API_SLOW_THRESHOLD_MS=2200
API_FAIL_SAFE_STREAK=4
NETWORK_RECOVERY_STREAK=1
