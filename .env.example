# Dry-run template.
# For live trading, start from .env.live.example instead.

# Mode
DRY_RUN=true

# Risk
MIN_EQUITY=5.0
MAX_ORDER_USD=1.0
MIN_LIVE_ORDER_SHARES=5.0
MIN_LIVE_ORDER_USD=1.0
LIVE_ORDER_AUTO_BUMP_USD=0.05
MAX_EXPOSURE_USD=3.0
MAX_ORDERS_PER_5MIN=1
MAX_CONSEC_LOSS=3
DAILY_MAX_LOSS=2.0

# Runtime
POLL_SECONDS=15

# Notifications (optional)
DISCORD_WEBHOOK_URL=

# Polymarket CLOB
CLOB_HOST=https://clob.polymarket.com
DATA_API_HOST=https://data-api.polymarket.com
CHAIN_ID=137
SIGNATURE_TYPE=1
PRIVATE_KEY=
FUNDER_ADDRESS=

# Auto market selection (recommended)
AUTO_MARKET_SELECTION=true
MARKET_SLUG_PREFIX=btc-updown-5m-

# Integrated rules from paper simulations
EDGE_THRESHOLD=0.02
SCOREBOARD_NEUTRAL_PNL_PCT=0.001
SCOREBOARD_ENTRY_GATE_MIN_DECISIVE_TRADES=5
FEE_BUFFER=0.01
ZSCORE_WINDOW=10
ZSCORE_THRESHOLD=2.2
ENTRY_WINDOW_MIN_SEC=40
ENTRY_WINDOW_MAX_SEC=95
MIN_ENTRY_PRICE=0.2
MAX_ENTRY_PRICE=0.8

# Optional static token ids (used when AUTO_MARKET_SELECTION=false)
TOKEN_ID_UP=
TOKEN_ID_DOWN=

# Phase 3: Entry & Exit Quality Guards
ENABLE_HARD_STOP_SHIELD=false
HARD_STOP_SHIELD_VELOCITY=0.0
LATE_ENTRY_EDGE_PENALTY=0.015
RICH_PRICE_EDGE_PENALTY=0.015
BINARY_KELLY_DIVISOR=4.0
FORCE_FULL_EXIT_ON_TAKE_PROFIT=false
FORCE_FULL_EXIT_ON_STOP_LOSS_SCALEOUT=false
FAILED_FOLLOW_THROUGH_WINDOW_SEC=45
FAILED_FOLLOW_THROUGH_LOSS_PCT=0.03
FAILED_FOLLOW_THROUGH_MAX_MFE_PCT=0.02
FAILED_FOLLOW_THROUGH_MIN_SECS_LEFT=90
WS_STALE_MAX_AGE_SEC=5
WS_STALE_FAIL_SAFE_STREAK=2
API_SLOW_THRESHOLD_MS=1500
API_FAIL_SAFE_STREAK=3
NETWORK_RECOVERY_STREAK=2
ENTRY_VELOCITY_MIN=0.0002
